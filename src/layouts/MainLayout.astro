---
import "@/styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}
const { title = "Astro", description = "An Astro website." } = Astro.props;
const bgTop = `url(${import.meta.env.BASE_URL}bg-pattern-top.svg)`;
const bgBottom = `url(${import.meta.env.BASE_URL}bg-pattern-bottom.svg)`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link
      rel="icon"
      sizes="32x32"
      type="image/png"
      href={`${import.meta.env.BASE_URL}favicon-32x32.png`}
    />
    <title>{title}</title>

    <Font cssVariable="--font-kumbh-sans" preload />
    <ClientRouter />
  </head>
  <body class="bg-theme-blue-600 font-kumbh-sans">
    <slot />
  </body>
</html>

<style define:vars={{ bgTop, bgBottom }}>
  body {
    background-image: var(--bgTop), var(--bgBottom);
    background-position:
      right 50vw bottom 45vh,
      left 50vw top 50vh;
    background-repeat: no-repeat;
  }
</style>
