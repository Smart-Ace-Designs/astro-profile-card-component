---
import type { Profile } from "@/utils/Profile";
import MainLayout from "@/layouts/MainLayout.astro";
import AppProfileCard from "@/components/AppProfileCard.astro";

const user: Profile = {
  name: "Victor Crest",
  age: 26,
  location: "London",
  followers: "80K",
  likes: "803K",
  photos: "1.4K",
};
---

<MainLayout
  title="Frontend Mentor | Profile Card Component"
  description="A profile card component challenge from Frontend Mentor."
>
  <main class="flex min-h-screen justify-center pt-43">
    <AppProfileCard user={user} />
  </main>
</MainLayout>
