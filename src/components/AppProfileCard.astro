---
import type { Profile } from "@/utils/Profile";

interface Props {
  user: Profile;
}

const { user } = Astro.props;
const background = `url(${import.meta.env.BASE_URL}bg-pattern-card.svg)`;
---

<section class="h-93.75 w-full max-w-87.5 overflow-hidden rounded-[15px]">
  <div class="responsive-bg relative h-35 w-full bg-cover bg-center bg-no-repeat">
    <img
      src="image-victor.jpg"
      alt={user.name}
      class="absolute top-full left-1/2 z-1 size-26 -translate-1/2 rounded-full border-[5px] border-white"
      width="104"
      height="104"
    />
  </div>
  <div class="bg-white pt-14 pb-6 text-center">
    <div class="flex flex-row items-center justify-center gap-2">
      <h1 class="text-lg font-extrabold text-theme-navy-950">
        {user.name}
      </h1>
      <p class="text-lg font-medium text-theme-gray-500">{user.age}</p>
    </div>
    <p class="text-sm text-theme-gray-500">{user.location}</p>
  </div>
  <div class="flex flex-row justify-between border-t border-theme-gray-100 bg-white p-8">
    <div class="text-center">
      <p class="text-lg font-bold text-theme-navy-950">{user.followers}</p>
      <p class="text-[10px] tracking-widest text-theme-gray-500">Followers</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-theme-navy-950">{user.likes}</p>
      <p class="text-[10px] tracking-widest text-theme-gray-500">Likes</p>
    </div>
    <div class="text-center">
      <p class="text-lg font-bold text-theme-navy-950">{user.photos}</p>
      <p class="text-[10px] tracking-widest text-theme-gray-500">Photos</p>
    </div>
  </div>
</section>

<style define:vars={{ background }}>
  .responsive-bg {
    background-image: var(--background);
  }
</style>
