---
interface Props {
  name: string;
  age: string;
  location: string;
}

const { name, age, location } = Astro.props;
---

<section class="w-full max-w-84 overflow-hidden rounded-2xl">
  <div class="h-32 w-full bg-[url(/bg-pattern-card.svg)]"></div>
  <div>
    <img src="image-victor.jpg" alt={name} />
  </div>
  <div class="bg-white text-center">
    <h1 class="font-extrabold text-theme-navy-950">
      {name}
      <span class="font-normal text-theme-gray-500">{age}</span>
    </h1>
    <p class="text-sm text-theme-gray-500">{location}</p>
  </div>
  <div class="flex flex-row gap-x-8 bg-white p-8">
    <div>
      <p>80K</p>
      <p>Followers</p>
    </div>
    <div>
      <p>803K</p>
      <p>Like</p>
    </div>
    <div>
      <p>1.4K</p>
      <p>Photos</p>
    </div>
  </div>
</section>
