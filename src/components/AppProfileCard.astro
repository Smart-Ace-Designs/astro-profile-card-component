---
interface Props {
  name: string;
  age: string;
  location: string;
}

const { name, age, location } = Astro.props;
---

<section class="mt-43 h-[375px] w-full max-w-[350px] overflow-hidden rounded-[15px]">
  <div class="h-35 w-full bg-[url(/bg-pattern-card.svg)] bg-cover bg-center bg-no-repeat"></div>
  <div class="bg-white text-center">
    <img src="image-victor.jpg" alt={name} class="mx-auto rounded-full" />
    <h1 class="font-extrabold text-theme-navy-950">
      {name}
      <span class="font-normal text-theme-gray-500">{age}</span>
    </h1>
    <p class="text-sm text-theme-gray-500">{location}</p>
  </div>
  <div class="flex flex-row justify-between bg-white p-8">
    <div>
      <p>80K</p>
      <p>Followers</p>
    </div>
    <div>
      <p>803K</p>
      <p>Like</p>
    </div>
    <div>
      <p>1.4K</p>
      <p>Photos</p>
    </div>
  </div>
</section>
